# =============================================================================
# Reactive Resume v5 - Environment Variables
# Copy this file to .env.rxresume and fill in your values.
# This file is consumed by the rxresume-app service in docker-compose.yml.
# =============================================================================

# -- Database (PostgreSQL) ------------------------------------------------
POSTGRES_USER=rxresume
POSTGRES_PASSWORD=your_secure_db_password_here
POSTGRES_DB=rxresume
DATABASE_URL=postgresql://rxresume:your_secure_db_password_here@rxresume-db:5432/rxresume

# -- App -------------------------------------------------------------------
PUBLIC_URL=http://localhost:3000
APP_URL=http://localhost:3000

# Generate strong random keys:
#   pwsh: -join ([char[]](0x30..0x39 + 0x41..0x5A + 0x61..0x7A) * 64 | Get-Random -Count 64)
#   bash: openssl rand -base64 32
AUTH_SECRET=your_super_secret_auth_key_here
REFRESH_TOKEN_SECRET=your_super_secret_refresh_key_here

# Storage URL (used for generated PDF file URLs)
STORAGE_URL=http://localhost:3000/api/storage
